# ──────────────────────────────────────────────────────────────────────────────
# LLM Configuration
# Copy this file to .env and uncomment the block that matches your setup.
# .env is gitignored and will never be committed.
# ──────────────────────────────────────────────────────────────────────────────


# ── Option 1: NSCC Truro Campus AI Cluster (local vLLM) ───────────────────────
# Recommended. Runs Qwen 32B on-premises — no data leaves the network.
#
LLM_BASE_URL=http://172.16.147.126:8001/v1
LLM_MODEL=qwen-32b
LLM_API_KEY=none


# ── Option 2: Ollama (local) ───────────────────────────────────────────────────
# Install Ollama from https://ollama.com, then: ollama pull <model>
# Replace LLM_MODEL with whichever model you have pulled.
#
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama


# ── Option 3: LM Studio (local) ───────────────────────────────────────────────
# Start LM Studio and enable the local server. Use the model name shown in the UI.
#
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=your-loaded-model-name
# LLM_API_KEY=lm-studio


# ── Option 4: OpenAI (cloud) ───────────────────────────────────────────────────
# Note: curriculum data will be sent to OpenAI's servers.
# Get your API key from https://platform.openai.com/api-keys
#
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-api-key-here


# ── Note on Anthropic / Claude ─────────────────────────────────────────────────
# The Anthropic API uses a different SDK and is not directly supported by this
# script. If you need Claude, the easiest path is to use a proxy that exposes
# an OpenAI-compatible endpoint (e.g. LiteLLM), then configure it like Option 3.
